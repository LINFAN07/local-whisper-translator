{
  "name": "voice-translator-app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/with-short-cwd.cjs dev:next",
    "dev:next": "next dev --turbopack -p 3001",
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "electron:dev:clean": "npm run clean:next && npm run electron:dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup:python": "node scripts/setup-python.cjs",
    "electron:dev": "node scripts/with-short-cwd.cjs electron:start",
    "electron:start": "concurrently -k \"cross-env NODE_ENV=development next dev --turbopack -p 3001\" \"wait-on http://127.0.0.1:3001 && cross-env NODE_ENV=development ELECTRON_DEV_SERVER_URL=http://127.0.0.1:3001 electron .\"",
    "build:electron-static": "cross-env ELECTRON_EXPORT=true next build",
    "electron:pack": "cross-env ELECTRON_EXPORT=true next build && electron-builder",
    "electron:dist:win": "cross-env ELECTRON_EXPORT=true next build && electron-builder --win",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.voicetranslator.app",
    "productName": "語音辨識與翻譯",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "out",
        "to": "out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python_service",
        "to": "python_service",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@vitalets/google-translate-api": "^9.2.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.7.0",
    "next": "^15.2.4",
    "openai": "^6.33.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/verror": "^1.10.11",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
